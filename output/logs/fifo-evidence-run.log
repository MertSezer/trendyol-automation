          if (!isVisible(el)) continue;

          try {
            el.scrollIntoView({ block: "center", inline: "center" });
            el.click();
            return { ok: true, selector: sel, text: txt.slice(0, 200) };
          } catch (_) {}
        }
      }

      return { ok: false, mode: "add-button-not-found" };
    }
