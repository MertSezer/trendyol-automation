    "type":  "commonjs",
    "devDependencies":  {
                            "@playwright/test":  "^1.58.2",
                            "@wdio/protocols":  "^9.24.0",
                            "ajv":  "^8.18.0",
                            "ajv-formats":  "^3.0.1",
                            "allure-commandline":  "^2.38.0",
                            "allure-js-commons":  "^3.6.0",
                            "chromedriver":  "^146.0.0",
                            "codeceptjs":  "^3.7.8",
                            "cross-env":  "^10.1.0",
                            "dotenv":  "^17.3.1",
                            "playwright":  "^1.55.1",
                            "webdriverio":  "^9.24.0"
                        },
    "dependencies":  {
                         "mochawesome":  "^7.1.4",
                         "selenium-webdriver":  "^4.41.0"
                     }
}
